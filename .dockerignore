# Never copy build output, test projects, or scratch into the build context.
# Only source files the AOT publish actually needs.
bin/
obj/
publish/

# The test project builds an xUnit DLL that the container never runs. Its
# sources would only pull ~100 MB of test NuGets through `dotnet restore`.
dmart.Tests/

# Hoisted node_modules from the yarn workspace at repo root — the host
# build (build-ui.sh) populates this; the production Dockerfile only
# consumes the dist/client outputs and never needs the install tree.
/node_modules/

# CXB is built by build-ui.sh on the host; the production Dockerfile only
# consumes cxb/dist/client/. Don't ship source, node_modules, or svelte-kit
# cache into the Docker build context.
cxb/node_modules/
cxb/.svelte-kit/
cxb/dist/
!cxb/dist/client/
cxb/src/
cxb/static/
cxb/tests/

# Same pattern for catalog — only catalog/dist/client/ makes it into the
# build context, and the dmart.csproj EmbeddedResource glob picks it up.
catalog/node_modules/
catalog/.svelte-kit/
catalog/dist/
!catalog/dist/client/
catalog/src/
catalog/static/
catalog/public/
catalog/spaces/

# Git history is irrelevant at build time; build.sh bakes git-describe into
# the binary via -p:InformationalVersion long before docker.
.git/
.github/

# Local scratch.
*.tar.gz
*.zip
*.log
.dmart/
config.env
memory/
